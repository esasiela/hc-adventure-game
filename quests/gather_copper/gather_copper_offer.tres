metadata/_custom_type_script = "uid://bcq7s40seq3ik"

[sub_resource type="Resource" id="Resource_cp7qj"]
script = ExtResource("2_sh8hx")
speaker = "Aldwin"
text = "Ah, a traveler! Tell me, would you happen to be heading toward the cliffs?"
metadata/_custom_type_script = "uid://baauah4044ivb"

[sub_resource type="Resource" id="Resource_sh8hx"]
script = ExtResource("2_sh8hx")
speaker = "Aldwin"
text = "I've been low on copper for weeks. It is a real problem."
metadata/_custom_type_script = "uid://baauah4044ivb"

[sub_resource type="Resource" id="Resource_w0q58"]
script = ExtResource("2_sh8hx")
speaker = "Aldwin"
text = "If you could bring me some pieces of copper ore, I'd reward you well."
metadata/_custom_type_script = "uid://baauah4044ivb"

